# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# AWS
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=your_12_digit_account_id

# RDS (fill in after running setup_rds.py)
RDS_HOST=your-rds-instance.xxxxxxxxxxxx.eu-west-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DB=postgres
RDS_USER=postgres
RDS_PASSWORD=your_rds_password

# S3 (fill in your bucket name)
S3_BUCKET=your-techdocs-bucket-name

# Bedrock Agents (fill in after running setup_bedrock_agents.py)
SUPERVISOR_AGENT_ID=
SUPERVISOR_AGENT_ALIAS_ID=
